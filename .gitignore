# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# eval scorecards — non-deterministic API output, not worth committing (the golden set is)
/evals/scorecards

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel
    
# typescript
*.tsbuildinfo
next-env.d.ts
AGENTS.md
CLAUDE.md

# local build-experience log (ADRs + bug write-ups) — not shipped, not committed
/notes
# the hook that nudges me to keep notes/ up to date — part of the same local workflow
/.claude/hooks/notes-reminder.sh
